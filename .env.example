# Node Configuration
NODE_ID=node-1
PEER_URLS=http://node-2:8000,http://node-3:8000

# Rate Limiting
RATE_LIMIT_WINDOW_SECONDS=60
ANONYMOUS_LIMIT=10
VIEWER_LIMIT=30
EDITOR_LIMIT=60
ADMIN_LIMIT=120

# Gossip Protocol
GOSSIP_INTERVAL_SECONDS=0.5
GOSSIP_FANOUT=2
GOSSIP_SECRET_KEY=your-super-secret-gossip-key-change-in-production

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Demo auth users
ENABLE_DEMO_USERS=false
# Set these only when ENABLE_DEMO_USERS=true
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=
VIEWER_USER_ID=viewer-1
VIEWER_EMAIL=viewer@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_USER_ID=admin-1
ADMIN_EMAIL=admin@example.com
